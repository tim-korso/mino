# macOS
.DS_Store

# Local runtime
.playwright-mcp/

# Daily workspace (temp tasks, don't track)
workspace/

# Windows workspace (tracked — machine-specific)
!windows/workspace/

# Generated images (ignore loose, track in folder)
*.png
*.jpeg
*.jpg
!generated-images/

# Backups
*.zip
.claude/hooks/backups/

# Claude Code auto-memory (separate from your memory system)
.claude-auto-memory/

# Credentials (never commit secrets)
.config/
myagents_files/
ikebana/.local-packages/
.claude/plans/myagents/
workspace/claims.db
